med:P168 sh:path med:manifeste;
  sh:name "manifeste";
  sh:description "Référence à un Element de Spécialité dont cet élément de présentation est une manifestation concrète.";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:Element;
  shacl-play:background-color "#EAF1DD" .

med:P169 sh:path med:typeContenantLitteral;
  sh:name "type de contenant (littéral)";
  sh:description "Le conditionnement primaire qui contient le médicament, indépendemment de tous les éventuels dispositifs d'administration qui sont \"autour\", sous forme de chaine de caractères non-normalisée.";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:string;
  shacl-play:background-color "#EAF1DD" .

med:P170 sh:path med:typeContenant;
  sh:name "type de contenant";
  sh:description "Le conditionnement primaire qui contient le médicament, indépendemment de tous les éventuels dispositifs d'administration qui sont \"autour\".";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:TypeContenant .

med:P171 sh:path med:classementSubstanceDosageForme;
  sh:name "classement par substance, dosage et forme";
  sh:description """Classement de cet élément de présentation sur un PhPID4. Cet attribut est toujours renseigné, sauf dans le cas des spécialités non virtualisables, pour lesquelles c'est seulement le classement par substance qui est indiqué.
Cet attribut peut être répété pour le cas où un même élément dans une présentation pourrait donner lieu à plusieurs formes administrables.""";
  sh:nodeKind sh:IRI;
  sh:class med:PPhParSubstanceDosageForme .

med:P172 sh:path med:classementSubstance;
  sh:name "classement par substance";
  sh:description "Classement de cet élément de présentation sur un PhPID1. Cet attribut est renseigné seulement pour les spécialités non virtualisables.";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:PPhParSubstance .

med:P173 sh:path med:formeAdministrable;
  sh:name "forme administrable";
  sh:description "Forme pharmaceutique administrable de cet élément";
  sh:nodeKind sh:IRI;
  sh:class med:Forme .

med:P174 sh:path med:dosagePresentation;
  sh:name "dosage présentation";
  sh:description "Dosage présentation possible pour cet élément dans cette présentation. En fonction des patrons de dosage, un élément peut se voir associer plusieurs dosages présentation possibles pour une substance donnée, par exemple \"10 mg\" ou \"10 mg/comprimé\". Ou encore \"40 mg/0,4 mL\" et \"40 mg/seringue\".";
  sh:minCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:DosagePresentation .

med:P175 sh:path med:uniteDePresentation;
  sh:name "unité de présentation";
  sh:description "Unité de présentation de cet élément de présentation";
  sh:nodeKind sh:IRI;
  sh:class med:UniteDePresentation .

med:P176 sh:path med:typeDose;
  sh:name "type de dose";
  sh:description "Indique le type de dose de cet élément dans la présentation : unidose (usage unique) ou multidose (usage multiple).";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:TypeDose .

