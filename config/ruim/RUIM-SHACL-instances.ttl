med:DosagePresentation a sh:NodeShape, rdfs:Class;
  rdfs:label "Dosage de présentation"@fr;
  rdfs:comment """Les dosages en présentation donnent une [quantité]((#med:DosagePresentation_med:quantiteSubstance)) de [substance](#med:DosagePresentation_med:substance) contenue dans un [élément de présentation](#med:ElementPresentation), exprimée dans une certaine [unité](#med:DosagePresentation_med:unite) (“mg”, “mL”, “g”, etc.) ou éventuellement une plage de quantité ([inférieure](#med:DosagePresentation_med:quantiteSubstanceInf) / [supérieure](#med:DosagePresentation_med:quantiteSubstanceSup)). La quantité peut être exprimée par rapport : 
- à rien (_“10 mg”_) 
- à la [quantité totale dans la présentation](#med:DosagePresentation_med:quantitePresentation) (_“10 mg dans 100 mL”_) 
- à une [unité de présentation](#med:DosagePresentation_med:uniteDePresentation) (_“10 mg dans une seringue”_)"""@fr;
  foaf:depiction <images/dosages_presentation.png>, med:Diagramme_ElementDosages;
  sh:closed "true"^^xsd:boolean;
  sh:ignoredProperties _:d85f7e570c704b5b9b53672428339dae714;
  sh:nodeKind sh:IRI;
  sh:pattern "^http://data.esante.gouv.fr/ansm/medicament/Dosage_.*$";
  shacl-play:background-color "808080";
  sh:property med:P51, med:P52, med:P53, med:P54, med:P55, med:P56, med:P57, med:P58,
    med:P59, med:P60, med:P61;
  sh:sparql med:BusinessRule_9 .

