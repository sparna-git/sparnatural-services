med:P118 sh:path med:dosageConcentration;
  sh:name "dosage concentration";
  sh:description """Dosage en concentration de cet élément. Le dosage en concentration ne dépend pas du volume du contenant et est donc indiqué sur l'élément, contrairement au dosage présentation. 
Un élément ne peut avoir qu'un seul dosage en concentration pour une substance donnée.""";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:DosageConcentration .

