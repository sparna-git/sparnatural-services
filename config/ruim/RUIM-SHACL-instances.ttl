med:P29 sh:path rdfs:label;
  sh:name "libellé";
  sh:description """Libellé du PhPID4.
Nom de la substance ou concaténation des noms des substances, séparés par un '+', par ordre alphabétique, suivi de l'expression de dosage, suivi du libellé de la forme pharmaceutique administrable normalisée.""";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype rdf:langString;
  dash:propertyRole dash:LabelRole;
  sh:languageIn _:d85f7e570c704b5b9b53672428339dae798 .

_:d85f7e570c704b5b9b53672428339dae798 rdf:first "fr";
  rdf:rest rdf:nil .

med:P30 sh:path med:substancePortantLeDosage;
  sh:name "substance qui porte le dosage";
  sh:description """Substance définissant ce PhPID.
La substance est soit une substance dans un référentiel EMA, soit une substance technique.
Le PhPID regroupe les médicaments contenant les substances indiquées, et seulement ces substances.
Il n'y a pas de restriction sur le nombre maximum de substances indiquées.""";
  sh:minCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:Substance .

med:P31 sh:path med:dosagePresentation;
  sh:name "dosage présentation";
  sh:description """Dosage de présentation définissant ce PhPID.
En fonction des patrons de dosage, les dosages présentation et concentration peuvent être présents ou absents. Au moins un dosage (présentation ou concentration) doit être indiqué.""";
  sh:nodeKind sh:IRI;
  sh:class med:DosagePresentation .

med:P32 sh:path med:dosageConcentration;
  sh:name "dosage concentration";
  sh:description """Dosage de concentration définissant ce PhPID.
En fonction des patrons de dosage, les dosages présentation et concentration peuvent être présents ou absents. Au moins un dosage (présentation ou concentration) doit être indiqué.""";
  sh:nodeKind sh:IRI;
  sh:class med:DosageConcentration .

med:P33 sh:path med:formeAdministrable;
  sh:name "forme administrable";
  sh:description """Forme pharmaceutique administrable définissant ce PhPID.
Il s'agit d'une forme pharmaceutique administrable normalisée, et non pas d'une forme pharmaceutique manufacturée.""";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:Forme .

med:P34 sh:path med:precisePPhParSubstanceDosage;
  sh:name "précise produit pharmaceutique par substance et dosage";
  sh:description "Lien vers le PhPID2 que ce PHPID4 précise.";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:PPhParSubstanceDosage .

med:P35 sh:path med:precisePPhParSubstanceForme;
  sh:name "précise produit pharmaceutique par substance et forme";
  sh:description "Lien vers le PhPID3 que ce PHPID4 précise.";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:PPhParSubstanceForme .

med:P37 sh:path skos:notation;
  sh:name "identifiant";
  sh:description "Identifiant de la prescription en DC";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:datatype xsd:string .

med:P38 sh:path rdfs:label;
  sh:name "libellé de prescription";
  sh:description """Libellé normalisé de prescription.
Nom de la substance ou concaténation des noms des substances, séparés par un '+', par ordre alphabétique, suivi de l'expression de dosage normalisée, suivi de la forme pharmaceutique manufacturée normalisée, suivi de la voie d'administration normalisée.""";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype rdf:langString;
  dash:propertyRole dash:LabelRole;
  sh:languageIn _:d85f7e570c704b5b9b53672428339dae799 .

_:d85f7e570c704b5b9b53672428339dae799 rdf:first "fr";
  rdf:rest rdf:nil .

med:P39 sh:path med:dateDebut;
  sh:name "date de début de validité";
  sh:description "Date de début de validité de ce libellé de prescription";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:date .

med:P40 sh:path med:dateFin;
  sh:name "date de fin de validité";
  sh:description "Date de fin de validité de ce libellé de prescription";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:date .

med:P41 sh:path med:actif;
  sh:name "actif";
  sh:description "Booléen indiquant si ce libellé est actif.";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:boolean .

med:P42 sh:path med:substancePortantLeDosage;
  sh:name "substance qui porte le dosage";
  sh:description """Substance définissant ce libellé de prescription.
Une prescription en DC peut indiquer 3 substances au maximum.""";
  rdfs:comment "Note : sur la prescription en DC on peut avoir 3 substances maximum. Les PhPID ne sont pas limités en nombre de substances";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "3"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:Substance .

med:P43 sh:path med:dosagePresentation;
  sh:name "dosage présentation";
  sh:description """Dosage de présentation définissant ce libellé de prescription.
En fonction des patrons de dosage, les dosages présentation et concentration peuvent être présents ou absents. Au moins un dosage (présentation ou concentration) doit être indiqué.""";
  sh:maxCount "6"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:DosagePresentation .

med:P44 sh:path med:dosageConcentration;
  sh:name "dosage concentration";
  sh:description """Dosage de présentation définissant ce libellé de prescription.
En fonction des motifs de dosage, les dosages présentation et concentration peuvent être présents ou omis. Au moins un dosage (présentation ou concentration) doit être indiqué.""";
  sh:maxCount "6"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:DosageConcentration .

med:P45 sh:path med:formeManufacturee;
  sh:name "forme manufacturée";
  sh:description """Forme pharmaceutique manufacturée normalisée définissant ce libellé de prescription.
Il s'agit d'une forme manufacturée, par opposition à la forme administrable qui définit les PhPID.

La forme pharmaceutique administrable peut être déduite de la forme pharmaceutique manufacturée et de la voie (1 forme pharmaceutique manufacturée + 1 voie = 1 forme pharmaceutique administrable)""";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:Forme .

med:P46 sh:path med:voie;
  sh:name "voie d'administration";
  sh:description "La voie d'administration normalisée définissant ce libellé de prescription";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:Voie .

med:P47 sh:path med:uniteDePresentation;
  sh:name "unité de présentation";
  sh:description """L'unité de présentation normalisée définissant ce libellé de prescription.
L'unité de présentation peut être répétée sur le dosage présentation en fonction des patrons d'expression de dosage.""";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:UniteDePresentation .

med:P48 sh:path med:medicamentVirtuel;
  sh:name "médicament virtuel";
  sh:description """Lien vers le (ou les) médicament virtuel servant de base à la définition de ce libellé de prescription.
Ce lien est obligatoire, tous les libellés de prescription en DC doivent s'appuyer sur un médicament virtuel.
Dans certain cas une prescription en DC pourra correspondre à plusieurs médicaments virtuels (cas du Prasugrel)""";
  sh:minCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI .

med:P49 sh:path med:classementSubstanceDosageForme;
  sh:name "classement par substance, dosage et forme";
  sh:description """Lien vers un PhPID4 dans lequel est classé ce libellé de prescription.
Ce lien est obligatoire, tous les libellés de prescription en DC doivent être classés dans un PhPID4.""";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:PPhParSubstanceDosageForme .

med:P51 sh:path rdfs:label;
  sh:name "libellé du dosage";
  sh:description "Libellé de ce dosage. Même si formellement le modèle n'a pas besoin d'un libellé pour le dosage, il est obligatoire pour l'affichage dans le SMT. Le libellé du dosage est caculé de façon automatique à partir de ses caractéristiques.";
  rdfs:comment "Uniquement pour des questions d'affichage dans le SMT";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype rdf:langString;
  dash:propertyRole dash:LabelRole .

med:P52 sh:path med:substance;
  sh:name "substance";
  sh:description "substance pour laquelle est exprimé ce dosage";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:Substance .

med:P53 sh:path med:quantiteSubstance;
  sh:name "quantité de substance";
  sh:description "Quantité de la substance. Cet attribut est renseigné pour les dosages exacts (cas le plus fréquent), mais pas pour les dosages par intervalle, qui utilisent les bornes inférieures et supérieures.";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:decimal .

med:P54 sh:path med:unite;
  sh:name "unité de la quantité de substance";
  sh:description "Code de l'unité de mesure de la quantité de substance normalisé dans la grammaire UCUM. Cet attribut est toujours renseigné pour les dosages exacts (cas le plus fréquent), mais pas pour les dosages par intervalle, qui utilisent les bornes inférieures et supérieures.";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype cdt:ucumunit .

med:P55 sh:path med:quantiteSubstanceInf;
  sh:name "quantité de substance - borne inférieure";
  sh:description "\"Au moins cette quantité de substance...\" : Borne inférieure d'un dosage exprimé par intervalle. Cet attribut n'est pas renseigné pour les dosages exacts.";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:decimal .

med:P56 sh:path med:uniteInf;
  sh:name "quantité de substance - borne inférieure - unité";
  sh:description "Code de l'unité de mesure de la borne inférieure d'un dosage par intervalle, normalisé dans la grammaire UCUM. Cet attribut n'est pas renseigné pour les dosages exacts.";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype cdt:ucumunit .

med:P57 sh:path med:quantiteSubstanceSup;
  sh:name "quantité de substance - borne supérieure";
  sh:description "\"Pas plus de cette quantité de substance...\" : Borne supérieure d'un dosage exprimé par intervalle. Cet attribut n'est pas renseigné pour les dosages exacts.";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:decimal .

med:P58 sh:path med:uniteSup;
  sh:name "quantité de substance - borne supérieure - unité";
  sh:description "Code de l'unité de mesure de la borne supérieure d'un dosage par intervalle, normalisé dans la grammaire UCUM. Cet attribut n'est pas renseigné pour les dosages exacts.";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype cdt:ucumunit .

med:P59 sh:path med:quantitePresentation;
  sh:name "quantité totale de la présentation";
  sh:description "Quantité ou volume total dans la présentation. Cet attribut est renseigné pour les dosages des formes liquides ou semi-solides dans un contenant (par exemple 50 mg/20mL)";
  rdfs:comment "Si la quantité de présentation est présente, son unité doit être indiquée, et l'unité de présentation ne peut pas être indiquée.";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:decimal .

med:P60 sh:path med:uniteQuantitePresentation;
  sh:name "unité de la quantité totale de présentation";
  sh:description "Code de l'unité de mesure de la quantité ou du volume total de la présentation, normalisé dans la grammaire UCUM. Cet attribut est présent seulement si on renseigne l'attribut de quantité totale dans la présentation.";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype cdt:ucumunit .

med:P61 sh:path med:uniteDePresentation;
  sh:name "unité de présentation";
  sh:description "Unité de présentation pour l'expression de ce dosage. Cet attribut est renseigné pour les dosages exprimés par unité de dose (par exemple 50 mL/seringue, 50mg/bouffée)";
  rdfs:comment "Si l'unité de présentation est indiquée, la quantité de présentation ne peut pas être présente";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:UniteDePresentation .

med:P63 sh:path rdfs:label;
  sh:name "libellé du dosage";
  sh:description "Libellé de ce dosage. Même si formellement le modèle n'a pas besoin d'un libellé pour le dosage, il est obligatoire pour l'affichage dans le SMT. Le libellé du dosage pourrait être caculé de façon automatique à partir de ses caractéristiques.";
  rdfs:comment "Uniquement pour des questions d'affichage dans le SMT";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype rdf:langString;
  dash:propertyRole dash:LabelRole .

med:P64 sh:path med:substance;
  sh:name "substance";
  sh:description "substance pour laquelle est exprimé ce dosage";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:Substance .

med:P65 sh:path med:quantiteSubstance;
  sh:name "concentration de la substance";
  sh:description "Concentration de la substance. Cet attribut est renseigné pour les dosages exacts (cas le plus fréquent), mais pas pour les dosages par intervalle, qui utilisent les bornes inférieures et supérieures.";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:decimal .

med:P66 sh:path med:quantiteSubstanceInf;
  sh:name "concentration de substance - borne inférieure";
  sh:description "\"Au moins cette concentration de substance...\" : Borne inférieure d'un dosage exprimé par intervalle. Cet attribut n'est pas renseigné pour les dosages exacts.";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:decimal .

med:P67 sh:path med:uniteInf;
  sh:name "concentration de substance - borne inférieure - unité";
  sh:description "Code de l'unité de mesure de la borne inférieure d'un dosage par intervalle, normalisé dans la grammaire UCUM. Cet attribut n'est pas renseigné pour les dosages exacts.";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype cdt:ucumunit .

med:P68 sh:path med:quantiteSubstanceSup;
  sh:name "concentration de substance - borne supérieure";
  sh:description "\"Pas plus de cette concentration de substance...\" : Borne supérieure d'un dosage exprimé par intervalle. Cet attribut n'est pas renseigné pour les dosages exacts.";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:decimal .

med:P69 sh:path med:uniteSup;
  sh:name "concentration de substance - borne supérieure - unité";
  sh:description "Code de l'unité de mesure de la borne supérieure d'un dosage par intervalle, normalisé dans la grammaire UCUM. Cet attribut n'est pas renseigné pour les dosages exacts.";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype cdt:ucumunit .

med:P70 sh:path med:unite;
  sh:name "unité de la concentration de la substance";
  sh:description "Code de l'unité de mesure de la concentration, normalisé dans la grammaire UCUM, exprimé soit en concentration par volume (par exemple mg/mL), par masse (par exemple mg/g) ou en débit (par exemple mg/24h)";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype cdt:ucumunit .

med:P71 sh:path med:exprimableEnPourcent;
  sh:name "exprimable en pourcent";
  sh:description """Indique si ce dosage en concentration peut être exprimé en pourcent en plus de l'indication de concentration, par exemple \"2,5% (25 mg/g)\" plutôt que simplement \"25 mg/g\".
Cela joue uniquement sur la façon de présenter ce dosage mais ce n'est pas une caractéristique formelle de celui-ci.
L'expression d'un dosage concentration en pourcent peut être utilisé dans les libellés de prescription en DC et certain libellés de PhPIDs correspondant à des gaz médicinaux, des pommades, des collyres, etc.""";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:boolean .

med:P73 sh:path rdfs:label;
  sh:name "libellé de l'unité";
  sh:description "libellé";
  rdfs:comment "Uniquement pour des questions d'affichage dans le SMT";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype rdf:langString;
  dash:propertyRole dash:LabelRole .

med:P74 sh:path med:codeUcum;
  sh:name "code UCUM";
  sh:description "Code de cette unité de mesure normalisé dans la grammaire UCUM.";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype cdt:ucumunit .

med:P75 sh:path med:multiplicateurPourcent;
  sh:name "multiplicateur pourcent";
  sh:description "Multiplicateur à utiliser pour convertir une quantité exprimée avec cette unité en pourcentage. Par exemple sur l'unité \"mg/g\", le multiplicateur pourcent est 0,1.";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:decimal .

med:P76 sh:path skos:exactMatch;
  sh:name "correspondance QUDT";
  sh:description """Correspondance avec l'URI de l'unité dans le vocabulaire des unités QUDT (https://www.qudt.org/doc/DOC_VOCAB-UNITS.html)
Ce lien est purement informatif.""";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI .

med:P78 sh:path med:CIS;
  sh:name "CIS";
  sh:description "Code CIS (code principal identifiant de la spécialité)";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:string;
  shacl-play:background-color "#EAF1DD" .

