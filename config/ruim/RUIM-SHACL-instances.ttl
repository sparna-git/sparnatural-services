  sh:nodeKind sh:IRI;
  sh:class med:GroupeGenerique;
  shacl-play:background-color "#EAF1DD" .

med:P106 sh:path med:estSpecialiteSubstituableDans;
  sh:name "est spécialité substituable dans";
