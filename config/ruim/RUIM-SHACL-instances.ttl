  sh:name "substance active";
  sh:description """Substance active dans l'élément (composant reconnu comme possédant des propriétés thérapeutiques).
Substance \"contenue dans la boite\" (qui n'est pas forcément identique à la substance dans laquelle est exprimée le dosage).""";
  sh:minCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:severity sh:Warning;
