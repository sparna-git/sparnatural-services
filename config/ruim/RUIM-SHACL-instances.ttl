med:P80 sh:path med:actif;
  sh:name "actif";
  sh:description "Indique si l'autorisation de cette spécialité est actuellement active (oui/non)";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:boolean;
  shacl-play:background-color "#EAF1DD" .

med:P81 sh:path med:dateDebut;
  sh:name "date de première AMM";
  sh:description "Date de la (première) AMM ou de la première autorisation de cette spécialité.";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:date;
  shacl-play:background-color "#EAF1DD" .

med:P82 sh:path med:dateFin;
  sh:name "date de fin";
  sh:description "Date à laquelle l'autorisation de cette spécialité n'est plus active.";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:date;
  shacl-play:background-color "#EAF1DD" .

med:P83 sh:path med:classificationATC;
  sh:name "classification ATC";
  sh:description """Référence à un élément de la classification ATC de cette spécialité. Cet attribut n'est pas historisé et contient la dernière valeur en date du code ATC. Les évolutions de l’ATC elle-même sont historisées dans le référentiel ATC. 
Pour certaines spécialités archivées, il est possible que la référence à l'ATC ne soit pas présente dans le cas où ce code aurait disparu avant l'ATC 2022. Après 2022 l'ATC est cumulative et mêmes les codes dépréciés restent présents.""";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  shacl-play:background-color "#EAF1DD" .

med:P84 sh:path med:codeATC;
  sh:name "code ATC";
  sh:description "Code ATC sous forme littérale (par exemple 'G04CA01'). Le code est explicitement répété en plus de la référence à l'URI principalement pour des questions d'affichage car le simple libellé de la catégorie est ambigü.";
  sh:agentInstruction "Pour filtrer une spécialité par classification ATC, utiliser la réconciliation avec le type <http://data.esante.gouv.fr/ema/sms> pour trouver l'entité ATC. Les entités ATC sont indexées sous la forme 'CODE - libellé' (ex: 'G04CA01 - Antagonistes des récepteurs alpha-adrénergiques'). Injecter ensuite l'URI réconciliée dans la propriété med:classificationATC — ne pas utiliser le code littéral de ce prédicat pour filtrer."@fr;
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:string;
  shacl-play:background-color "#EAF1DD" .

med:P85 sh:path med:libelleATC;
  sh:name "libellé ATC (données source)";
  sh:description "Le libellé de la classification ATC donné à cette spécialité dans les données source. En cas d'évolution de la classification ATC, ce libellé pourrait être différent du libellé de la classification ATC actuelle, et est conservé pour cette raison";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype rdf:langString;
  shacl-play:background-color "#EAF1DD" .

med:P86 sh:path med:concernePar;
  sh:name "concernée par";
  sh:description "Référence à un évènement qui concerne cette spécialité (autorisation, changement de statut, changement de procédure, etc.)";
  sh:nodeKind sh:IRI;
  sh:class med:Evenement;
  shacl-play:background-color "#EAF1DD" .

med:P87 sh:path med:typeProcedureCourante;
  sh:name "type de procédure courante";
  sh:description "Le régime de procédure courant de la spécialité. Le régime de procédure courant peut être différant du type de procédure de l'autorisation d'origine de la spécialité, dans les cas où un évènement à changé le type de procédure de la spécialité.";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:TypeProcedure;
  shacl-play:background-color "#EAF1DD" .

med:P88 sh:path med:statutCourant;
  sh:name "statut courant";
  sh:description """Le statut courant de la spécialité. Le statut peut évoluer au fil des évènements réglementaires qui concernent la spécialité.
Cet attribut capture seulement le dernier statut de la spécialité.""";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:StatutSpecialite;
  shacl-play:background-color "#EAF1DD" .

med:P89 sh:path med:seComposeDe;
  sh:name "se compose de ou des éléments";
  sh:description "Référence à un ou plusieurs éléments dans cette spécialité";
  sh:nodeKind sh:IRI;
  sh:class med:Element;
  shacl-play:background-color "#EAF1DD" .

med:P90 sh:path med:substanceActive;
  sh:name "substance active";
  sh:description """Substance active dans la spécialité (composant reconnu comme possédant des propriétés thérapeutiques).
Substance \"contenue dans la boite\" (qui n'est pas forcément identique à la substance dans laquelle est exprimée le dosage).
En principe toutes les spécialités ont au moins une substance active, mais des exceptions rares existent (les témoins de prick tests) où aucune substance active n'est répertoriée.""";
  sh:minCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:severity sh:Warning;
  sh:class med:Substance;
  shacl-play:background-color "#EAF1DD" .

med:P91 sh:path med:fractionTherapeutique;
  sh:name "fraction thérapeutique";
  sh:description """Substance qui porte l'activité pharmacologique, et qui est une partie d'une substance active.
Cette substance n'est donc pas directement \"contenue dans la boite\".
Toutes les spécialités n'ont pas forcément de fraction thérapeutique indiquée.""";
  sh:nodeKind sh:IRI;
  sh:class med:Substance;
  shacl-play:background-color "#EAF1DD" .

med:P92 sh:path med:substancePortantLeDosage;
  sh:name "substance qui porte le dosage";
  sh:description "Substance de cette spécialité dans laquelle est exprimée son dosage.";
  sh:minCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:severity sh:Warning;
  sh:class med:Substance;
  shacl-play:background-color "#EAF1DD" .

med:P93 sh:path med:formeManufacturee;
  sh:name "forme pharmaceutique pour la prescription";
  sh:description "Forme pharmaceutique pour la prescription de la Spécialité";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:Forme;
  shacl-play:background-color "#EAF1DD" .

med:P94 sh:path med:substancePortantLeDosageConnue;
  sh:name "substance qui porte le dosage connue";
  sh:description "Indique si la substance portant le dosage est connue pour cette spécialité. Cette valeur est à false si la substance portant le dosage n'est pas connue.";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:boolean;
  shacl-play:background-color "#EAF1DD" .

med:P95 sh:path med:aPourUniteDeDispensation;
  sh:name "a pour unité de dispensation";
  sh:description """Référence à une UCD qui dispense cette spécialité.
Une Spécialité peut être dispensée dans plusieurs UCD. Une Spécialité peut être dispensée dans plusieurs UCD. Elle est dispensée dans au moins une UCD.""";
  sh:minCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:UniteCommuneDeDispensation;
  shacl-play:background-color "#EAF1DD" .

med:P96 sh:path med:aPourPresentation;
  sh:name "a pour présentation";
  sh:description """Référence à une présentation qui présente cette spécialité.
Une Spécialité peut être présentée dans plusieurs présentations. Une Spécialité est présente dans au moins une présentation à partir du moment où elle a été commercialisée.""";
  sh:minCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:Presentation;
  shacl-play:background-color "#EAF1DD" .

med:P97 sh:path med:libelle;
  sh:name "libellé historisé";
  sh:description "Référence à un libellé historisé. Chaque libellé historisé porte une date de début, éventuellement une date de fin, et la valeur du libellé.";
  sh:minCount "1"^^xsd:integer;
  sh:node med:BlankNode_LabelWithDates .

med:P98 sh:path med:niveauDeVirtualisation;
  sh:name "niveau de virtualisation";
  sh:description "Indique a quel degré la spécialité peut être virtualisable : non virtualisable, virtualisable partiellement (uniquement en PhPID 1 par exemple), virtualisable complètement (jusqu'au PhPID 4).";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:NiveauVirtualisation .

med:P99 sh:path med:prescriptibiliteEnDC;
  sh:name "niveau de prescriptibilité en DC";
  sh:description "Indique a quel degré la spécialité est prescriptible en DC : prescriptible, non-prescriptible, prescriptible avec nom de marque.";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:NiveauPrescriptibilite;
  shacl-play:background-color "#EAF1DD" .

med:P100 sh:path med:justificationNiveauDeVirtualisation;
  sh:name "justification du niveau de virtualisation";
  sh:description """Indique la justification du positionnement du médicaument par rapport à son niveau de virtualisation (par exemple : pas de principe actif).
Cet attribut est obligatoire si le niveau de virtualisation de la spécialité est \"non virtualisable\" ou \"virtualisable partiellement\". Il peut être répété.""";
  sh:nodeKind sh:IRI;
  sh:class med:JustificationNiveauVirtualisation .

med:P101 sh:path med:justificationPrescriptibiliteEnDC;
  sh:name "justification de la prescriptibilité en DC";
  sh:description """Indique la justification du positionnement du médicament par rapport à la prescription en DC (par exemple : spécialité radiopharmaceutique , homéopathie, phytothérapie, gaz médicinal, etc.). 
Cet attribut est obligatoire si le médicament est \"non prescriptible\" ou \"prescriptible avec nom de marque\". Il est vide si le médicament est \"prescriptible en dénomination commune\". Il peut être répété.""";
  sh:nodeKind sh:IRI;
  sh:class med:JustificationNiveauPrescriptibilite;
  shacl-play:background-color "#EAF1DD" .

med:P102 sh:path med:titulaireCourant;
  sh:name "titulaire courant";
  sh:description """Le titulaire est le détenteur de l'autorisation. Le plus souvent, il s'agit d'un laboratoire pharmaceutique.
Cette propriété donne le titulaire courant de la spécialité, qui peut changer dans le temps. Dans le passé, il est possible qu'une spécialité ait eu des co-titulaires, dans ce cas cette propriété est renseignée deux fois.""";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "2"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:Organisation;
  shacl-play:background-color "#EAF1DD" .

med:P103 sh:path med:voie;
  sh:name "voie d'administration";
  sh:description "Une voie d'administration de cette spécialité";
  sh:minCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:Voie;
  shacl-play:background-color "#EAF1DD" .

med:P104 sh:path med:estSpecialiteDeReferenceDans;
  sh:name "est spécialité de référence dans";
  sh:description "Groupe générique pour lequel cette spécialité est la spécialité de référence";
  sh:nodeKind sh:IRI;
  sh:class med:GroupeGenerique;
  shacl-play:background-color "#EAF1DD" .

med:P105 sh:path med:estSpecialiteGeneriqueDans;
