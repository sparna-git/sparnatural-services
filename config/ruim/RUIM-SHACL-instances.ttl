  rdf:rest rdf:nil .

med:Presentation a sh:NodeShape, rdfs:Class;
  rdfs:label "Présentation"@fr;
  rdfs:comment """Une présentation est identifiée par son code [CIP13](#med:Presentation_med:CIP13). Elle est [liée à la spécialité](#med:Presentation_med:presente) présentée et à l’UCD [contenue dans la présentation](#med:Presentation_med:contientUniteDeDispensation). Conceptuellement, la présentation “[hérite](#med:Presentation_rdfs:subClassOf)” de toutes les caractéristiques de la spécialité dispensée (substances, type de conditionnement, forme manufacturée). La présentation peut être [prescriptible](#med:Presentation_med:prescriptibleComme) dans une ou plusieurs définitions de prescriptions en dénomination commune, si la spécialité dispensée est prescriptible en DC. 

Une présentation porte également l’[historique](#med:Presentation_med:libelle) de tous ses noms. 

La [forme manufacturée](#med:Presentation_med:formeManufacturee) ainsi que les [voies d’administration possibles](#med:Presentation_med:voie) sont indiquées sur les présentations. La forme peut être plus spécifique que la forme indiquée au niveau de la spécialité, par exemple _\"solution\"_ sur la spécialité, et _\"solution en ampoule\"_ ou _\"solution en flacon\"_ sur des présentations."""@fr;
  foaf:depiction <images/presentations.png>, med:Diagramme_SpecialitesPresentationsUCD;
  sh:closed "true"^^xsd:boolean;
  sh:ignoredProperties _:d85f7e570c704b5b9b53672428339dae696;
  sh:nodeKind sh:IRI;
  sh:pattern "^http://data.esante.gouv.fr/ansm/medicament/Presentation_.*$";
  shacl-play:background-color "7030A0";
  sh:property med:P143, med:P144, med:P145, med:P146, med:P147, med:P148, med:P149,
    med:P150, med:P151, med:P152, med:P153, med:P154, med:P155, med:P156, med:P157, med:P158,
    med:P159, med:P160, med:P161, med:P162;
  sh:sparql med:BusinessRule_3, med:BusinessRule_4, med:BusinessRule_10, med:BusinessRule_16 .

_:d85f7e570c704b5b9b53672428339dae696 rdf:first rdf:type;
  rdf:rest _:d85f7e570c704b5b9b53672428339dae697 .

_:d85f7e570c704b5b9b53672428339dae697 rdf:first rdfs:subClassOf;
  rdf:rest _:d85f7e570c704b5b9b53672428339dae698 .

_:d85f7e570c704b5b9b53672428339dae698 rdf:first owl:equivalentClass;
  rdf:rest rdf:nil .

med:UniteCommuneDeDispensation a sh:NodeShape, rdfs:Class;
  rdfs:label "Unité commune de dispensation"@fr;
  rdfs:comment "Une Unité Commune de dispensation est identifiée par son code [UCD13](#med:UniteCommuneDeDispensation_med:codeUCD13). Elle est liée d’une part [à sa spécialité pharmaceutique](#med:UniteCommuneDeDispensation_med:uniteDeDispensationDe) (une et une seule) et d’autre part [aux présentations](#med:UniteCommuneDeDispensation_med:presenteDans) dans lesquelles elle se retrouve (une UCD peut se retrouver dans plusieurs présentations). L’UCD porte l’[historique](#med:UniteCommuneDeDispensation_med:libelle) de tous ses noms."@fr;
  foaf:depiction <images/ucd.png>, med:Diagramme_SpecialitesPresentationsUCD;
  sh:closed "true"^^xsd:boolean;
  sh:ignoredProperties _:d85f7e570c704b5b9b53672428339dae699;
  sh:nodeKind sh:IRI;
  sh:pattern "^http://data.esante.gouv.fr/ansm/medicament/UCD_.*$";
  shacl-play:background-color "D52FCD";
  sh:property med:P136, med:P137, med:P138, med:P139, med:P140, med:P141 .

_:d85f7e570c704b5b9b53672428339dae699 rdf:first rdf:type;
  rdf:rest _:d85f7e570c704b5b9b53672428339dae700 .

_:d85f7e570c704b5b9b53672428339dae700 rdf:first rdfs:subClassOf;
  rdf:rest _:d85f7e570c704b5b9b53672428339dae701 .

_:d85f7e570c704b5b9b53672428339dae701 rdf:first owl:equivalentClass;
  rdf:rest rdf:nil .

med:GroupeGenerique a sh:NodeShape, rdfs:Class;
  rdfs:label "Groupe générique"@fr;
  rdfs:comment "Les groupes génériques regroupent les spécialités par des liens de différentes natures. Chaque groupe générique indique en général une [spécialité de référence](#med:GroupeGenerique_med:specialiteDeReference) (mais pas toujours, certains groupes n’ont aucune spécialité de référence), et donne les spécialités génériques [équivalentes](#med:GroupeGenerique_med:specialiteGenerique) et les autres spécialités [substituables](#med:GroupeGenerique_med:specialiteSubstituable)."@fr;
  foaf:depiction <images/groupes_generiques.png>;
  sh:closed "true"^^xsd:boolean;
  sh:ignoredProperties _:d85f7e570c704b5b9b53672428339dae702;
  sh:nodeKind sh:IRI;
  sh:pattern "^http://data.esante.gouv.fr/ansm/medicament/GroupeGenerique_.*$";
  shacl-play:background-color "C45911";
  sh:property med:P130, med:P131, med:P132, med:P133, med:P134 .

_:d85f7e570c704b5b9b53672428339dae702 rdf:first rdf:type;
  rdf:rest _:d85f7e570c704b5b9b53672428339dae703 .

_:d85f7e570c704b5b9b53672428339dae703 rdf:first rdfs:subClassOf;
  rdf:rest _:d85f7e570c704b5b9b53672428339dae704 .

_:d85f7e570c704b5b9b53672428339dae704 rdf:first owl:equivalentClass;
  rdf:rest rdf:nil .

med:Element a sh:NodeShape, rdfs:Class;
  rdfs:label "Elément"@fr;
  rdfs:comment """Une [spécialité](#med:SpecialitePharmaceutique) se compose d’un ou plusieurs éléments (exemple _\"comprimé bleu\"_, _\"gélule rouge\"_, _compartiment d’une poche_). L'élément est la partie manufacturée d'une spécialité pharmaceutique, à laquelle est associée une composition qualitative et quantitative. 

Les éléments sont identifiés par leur [numéro d’ordre séquentiel](#med:Element_med:identifiantElement) dans la spécialité. Ils sont associés à leur forme manufacturée (donnée sous [forme littérale](#med:Element_med:formeManufactureeLitterale) et sous forme de [référence à une liste contrôlée de formes](#med:Element_med:formeManufacturee))"""@fr;
  foaf:depiction <images/elements.png>, <images/composition_qualitative.png>, med:Diagramme_ElementDosages;
  sh:closed "true"^^xsd:boolean;
  sh:ignoredProperties _:d85f7e570c704b5b9b53672428339dae705;
  sh:nodeKind sh:IRI;
  sh:pattern "^http://data.esante.gouv.fr/ansm/medicament/Element_.*$";
  shacl-play:background-color "2F5696";
  sh:property med:P109, med:P110, med:P111, med:P112, med:P113, med:P114, med:P115,
    med:P116, med:P117, med:P118, med:P119 .

_:d85f7e570c704b5b9b53672428339dae705 rdf:first rdf:type;
  rdf:rest _:d85f7e570c704b5b9b53672428339dae706 .

_:d85f7e570c704b5b9b53672428339dae706 rdf:first rdfs:subClassOf;
  rdf:rest _:d85f7e570c704b5b9b53672428339dae707 .

_:d85f7e570c704b5b9b53672428339dae707 rdf:first owl:equivalentClass;
  rdf:rest rdf:nil .

med:ElementPresentation a sh:NodeShape, rdfs:Class;
  rdfs:label "Elément Présentation"@fr;
  rdfs:comment """De la même façon qu'une [Spécialité](#med:SpecialitePharmaceutique) se décompose en [éléments de Spécialité](#med:Element), une [Présentation](#med:Presentation) se décompose en éléments de Présentation. L'élément de Présentation représente les caractéristiques d'un élément de Spécialité donné *dans cette présentation donnée*. Le [type de contenant](#med:ElementPresentation_med:typeContenant) peut par exemple varier d'une présentation à l'autre, pour le même élément de Spécialité (solution buvable, tantôt en flacon, tantôt en ampoule). 

Les éléments de présentation peuvent être classés dans des catégories de produits pharmaceutiques, soit : 
- Sur un [PhPID4](#med:ElementPresentation_med:classementSubstanceDosageForme) si la spécialité dispensée est virtualisable. 
- Sur un [PhPID1](#med:ElementPresentation_med:classementSubstance) si la spécialité est non-virtualisable."""@fr;
  foaf:depiction <images/elements_presentation.png>, med:Diagramme_ElementDosages;
  sh:closed "true"^^xsd:boolean;
  sh:ignoredProperties _:d85f7e570c704b5b9b53672428339dae708;
  sh:nodeKind sh:IRI;
  sh:pattern "^http://data.esante.gouv.fr/ansm/medicament/ElementPresentation_.*$";
  shacl-play:background-color "2F5696";
  sh:property med:P164, med:P165, med:P166, med:P167, med:P168, med:P169, med:P170,
    med:P171, med:P172, med:P173, med:P174, med:P175, med:P176;
  sh:sparql med:BusinessRule_5, med:BusinessRule_6, med:BusinessRule_7, med:BusinessRule_8 .

