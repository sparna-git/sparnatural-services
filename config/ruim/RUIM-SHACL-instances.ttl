med:BusinessRule_1 a sh:SPARQLConstraint;
  dct:description "Toutes les substance de dosage d'un PhPID 2 doivent être présentes dans la liste des substances de ce PhPID"@fr;
  sh:message "La substance \"{?substanceDosage}\" n'existe pas dans la liste des substances de ce PhPID.";
  sh:select """PREFIX med: <http://data.esante.gouv.fr/ansm/medicament/>
SELECT $this ?substanceDosage
WHERE {
 $this (med:dosagePresentation|med:dosageConcentration)/med:substance ?substanceDosage .
 FILTER NOT EXISTS {
 $this med:substance ?substanceDosage .
 }
}""" .

med:BusinessRule_2 a sh:SPARQLConstraint;
  dct:description "Toutes les substance de dosage d'un PhPID 4 doivent être présentes dans la liste des substances de ce PhPID"@fr;
  sh:message "La substance \"{?substanceDosage}\" n'existe pas dans la liste des substances de ce PhPID.";
  sh:select """PREFIX med: <http://data.esante.gouv.fr/ansm/medicament/>
SELECT $this ?substanceDosage
WHERE {
 $this (med:dosagePresentation|med:dosageConcentration)/med:substance ?substanceDosage .
 FILTER NOT EXISTS {
 $this med:substance ?substanceDosage .
 }
}""" .

med:BusinessRule_3 a sh:SPARQLConstraint;
  dct:description "Seules les Présentations de Spécialités prescriptibles en DC peuvent avoir une prescription en DC."@fr;
  sh:message "La Présentation est liée à une prescription en DC sans que sa spécialitée soit prescriptible en DC.";
  sh:select """PREFIX med: <http://data.esante.gouv.fr/ansm/medicament/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT $this
WHERE {
 $this med:prescriptibleComme ?dc .
 FILTER NOT EXISTS {
 $this med:presente/med:prescriptibiliteEnDC ?niveauDc .
 # prescriptible en DC + avec nom de marque
 FILTER( ?niveauDc IN(med:NiveauPrescriptibilite_315 med:NiveauPrescriptibilite_317))
 }
}""" .

med:BusinessRule_4 a sh:SPARQLConstraint;
  dct:description "Toutes les Présentations de Spécialités prescriptibles en DC devraient avoir une prescription en DC"@fr;
  sh:message "La Présentation d'une Spécialité prescriptible en DC n'est pas liée à une prescription en DC.";
  sh:select """PREFIX med: <http://data.esante.gouv.fr/ansm/medicament/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT $this
WHERE {
 $this med:presente/med:prescriptibiliteEnDC ?niveauDc .
 # prescriptible en DC + avec nom de marque
 FILTER( ?niveauDc IN(med:NiveauPrescriptibilite_315 med:NiveauPrescriptibilite_317))
 FILTER NOT EXISTS {
 $this med:prescriptibleComme ?dc .
 }
}""" .

med:BusinessRule_5 a sh:SPARQLConstraint;
  dct:description "Seules les éléments présentation de Spécialités virtualisables peuvent avoir un classement sur un PhPID4."@fr;
  sh:message "L'élément présentation est lié à un PhPID4 sans que sa spécialité soit indiquée comme étant virtualisable.";
  sh:select """PREFIX med: <http://data.esante.gouv.fr/ansm/medicament/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT $this
WHERE {
 $this med:classementSubstanceDosageForme ?phpid4 .
 FILTER NOT EXISTS {
 $this med:compose/med:presente/med:niveauDeVirtualisation ?niveauVirt .
 FILTER( ?niveauVirt IN(med:Categorie_xx, med:Categorie_yy))
 }
}""" .

med:BusinessRule_6 a sh:SPARQLConstraint;
  dct:description "Tous les éléments présentation de Spécialités virtualisables devraient être classées dans un PhPID4"@fr;
  sh:message "L'élément présentation d'une Spécialité virtualisable n'est pas liée à un PhPID4";
  sh:select """PREFIX med: <http://data.esante.gouv.fr/ansm/medicament/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT $this
WHERE {
 $this med:compose/med:presente/med:niveauDeVirtualisation ?niveauVirt .
 FILTER( ?niveauVirt IN(med:Categorie_xx, med:Categorie_yy))
 FILTER NOT EXISTS {
 $this med:classementSubstanceDosageForme ?phpid4 .
 }
}""" .

med:BusinessRule_7 a sh:SPARQLConstraint;
  dct:description "Seuls les Elements Présentations de Spécialités partiellement virtualisables peuvent avoir un classement sur un PhPID1"@fr;
  sh:message "L'élément Présentation est lié à un PhPID1 sans être dans une Présentation d'une Spécialité partiellement virtualisable.";
  sh:select """PREFIX med: <http://data.esante.gouv.fr/ansm/medicament/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT $this
WHERE {
 $this med:classementSubstance ?phpid1 .
 FILTER NOT EXISTS {
 $this med:compose/med:presente/med:niveauDeVirtualisation ?niveauVirt .
 FILTER( ?categorie IN(med:Categorie_xx, med:Categorie_yy))
 }
}""" .

med:BusinessRule_8 a sh:SPARQLConstraint;
  dct:description "Tous les éléments présentation de Spécialités partiellement virtualisables devraient être classées dans un PhPID1"@fr;
  sh:message "L'élément Présentation d'une Spécialité partiellement virtualisable n'est pas liée à un PhPID1";
  sh:select """PREFIX med: <http://data.esante.gouv.fr/ansm/medicament/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT $this
WHERE {
 $this med:compose/med:presente/med:niveauDeVirtualisation ?niveauVirt .
 FILTER( ?categorie IN(med:Categorie_xx, med:Categorie_yy))
 FILTER NOT EXISTS {
 $this med:classementSubstance ?phpid1 .
 }
}""" .

med:BusinessRule_9 a sh:SPARQLConstraint;
  dct:description "Un dosage présentation ou concentration doit être exprimé soit avec une quantité de substance exacte, soit avec un intervalle de dosage."@fr;
  sh:message "Le dosage n'est pas exprimé avec une quantité exacte ni avec un intervalle";
  sh:select """PREFIX med: <http://data.esante.gouv.fr/ansm/medicament/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT $this
WHERE {
 FILTER NOT EXISTS { $this med:quantiteSubstance ?qtt }
 FILTER NOT EXISTS { $this med:quantiteSubstanceInf ?qttInf . }
 FILTER NOT EXISTS { $this med:quantiteSubstanceSup ?qttSup . }
}""" .

med:BusinessRule_10 a sh:SPARQLConstraint;
  dct:description "Le CIS d'une Présentation doit être le même que le CIS de l'UCD de cette Présentation"@fr;
  sh:message "La spécialité d'une Présentation ne se retrouve pas comme spécialité de l'UCD de cette Présentation";
  sh:select """PREFIX med: <http://data.esante.gouv.fr/ansm/medicament/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT $this
WHERE {
 $this med:presente ?specialite .
 $this med:contientUniteDeDispensation ?ucd .
 FILTER NOT EXISTS {
 ?ucd med:uniteDeDispensationDe ?specialite .
 }
}""" .

med:BusinessRule_11 a sh:SPARQLConstraint;
  dct:description "Il ne faut pas avoir de doublons de libellés de substances"@fr;
  sh:message "Le libellé de la substance est en doublon avec une autre substance";
  sh:select """PREFIX med: <http://data.esante.gouv.fr/ansm/medicament/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
SELECT DISTINCT $this ?autreSub ?value
WHERE {
 $this rdfs:label|skos:altLabel ?unNom .
 OPTIONAL { ?this <http://data.esante.gouv.fr/ansm/medicament/codeSMS> ?sms .}
 ?autreSub rdfs:subClassOf <http://data.esante.gouv.fr/ansm/medicament/Substance> .
 OPTIONAL {?autreSub <http://data.esante.gouv.fr/ansm/medicament/codeSMS> ?autreSMS . }
 FILTER(?autreSub != $this)
 ?autreSub rdfs:label|skos:altLabel ?unNom .
 BIND(?unNom AS ?value)
}""" .

med:BusinessRule_12 a sh:SPARQLConstraint;
  dct:description "Un synonyme de substance ne peut pas être en prefLabel"@fr;
  sh:message "Un synonyme de Substance existe également en prefLabel";
  sh:select """PREFIX med: <http://data.esante.gouv.fr/ansm/medicament/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
SELECT $this ?unNom ?value
WHERE {
 $this skos:altLabel ?unNom .
 $this rdfs:label ?unNom .
 BIND(?unNom AS ?value)
}""" .

med:BusinessRule_13 a sh:SPARQLConstraint;
  dct:description "Un libellé préférentiel de Substance ne doit pas comporter de parenthèses"@fr;
  sh:message "Un libellé préférentiel de Substance contient des parenthèses";
  sh:select """PREFIX med: <http://data.esante.gouv.fr/ansm/medicament/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
SELECT $this $PATH ?value
WHERE {
 $this rdfs:label ?value .
 FILTER( CONTAINS(STR(?value), \"(\") )
 FILTER( !CONTAINS(STR(?value), \"Homéopathie\") )
 BIND(rdfs:label AS $PATH)
}""" .

med:BusinessRule_14 a sh:SPARQLConstraint;
  dct:description "Une justification doit être indiquée si le niveau de prescriptibilité n'est pas \"prescriptible en DC\""@fr;
  sh:message "Une spécialité qui n'est pas prescriptible en DC n'a pas de justification associée.";
  sh:select """PREFIX med: <http://data.esante.gouv.fr/ansm/medicament/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
SELECT $this ?value
WHERE {
 $this med:prescriptibiliteEnDC ?value .
 FILTER(?value NOT IN (med:NiveauPrescriptibilite_315 med:NiveauPrescriptibilite_316))
 FILTER NOT EXISTS {
 $this med:justificationPrescriptibiliteEnDC ?justification .
 }
}""" .

med:BusinessRule_15 a sh:SPARQLConstraint;
  dct:description "Une justification doit être indiquée si le niveau de virtualisation n'est pas \"virtualisable\""@fr;
  sh:message "TEMP : Une spécialité qui n'est pas virtualisable n'a pas de justification associée.";
  sh:select """PREFIX med: <http://data.esante.gouv.fr/ansm/medicament/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
SELECT $this ?value
WHERE {
 $this med:niveauDeVirtualisation ?value .
 FILTER(?value != med:NiveauVirtualisation_XXX)
 FILTER NOT EXISTS {
 $this med:justificationNiveauDeVirtualisation ?justification .
 }
}""" .

med:BusinessRule_16 a sh:SPARQLConstraint;
  dct:description "Une Présentation ne peut avoir au maximum qu'un seul dosage concentration pour la même substance"@fr;
  sh:message "Une présentation ne peut avoir qu'un seul dosage concentration pour une substance donnée.";
  sh:select """PREFIX med: <http://data.esante.gouv.fr/ansm/medicament/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
SELECT $this ?value
WHERE {
 $this med:dosageConcentration ?dc .
 ?dc med:substance ?substance .
 $this med:dosageConcentration ?autreDc .
 ?autreDc med:substance ?substance .
 FILTER(?autreDc != ?dc && STR(?autreDc) < STR(?dc))
 BIND(?substance AS ?value) .
}""" .

med:SHACLConversionShape a sh:NodeShape;
  sh:targetSubjectsOf med:sousClasseDe;
  sh:rule med:turnIntoShClass .

med:turnIntoShClass a sh:SPARQLRule;
  rdfs:comment "Convertir les \"med:sousClasseDe\" en classical sh:class\"";
  sh:construct """PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX med: <http://data.esante.gouv.fr/ansm/medicament/>
CONSTRUCT {
 $this sh:node ?sousClasseDe
} WHERE {
 $this med:sousClasseDe ?sousClasseDe
}""" .

med:SHACLConversionShapeEverything a sh:NodeShape;
  sh:targetSubjectsOf sh:path, sh:property, rdf:first, dct:title, dct:description, dcat:downloadURL,
    sh:closed;
  sh:rule med:copiesEverything .

med:copiesEverything a sh:SPARQLRule;
  rdfs:comment "Recopie tout";
  sh:construct """PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX med: <http://data.esante.gouv.fr/ansm/medicament/>
CONSTRUCT {
 $this ?p ?o .
 $this sh:target ?target .
 ?target ?p2 ?o2 .
} WHERE {
 $this ?p ?o .
 OPTIONAL { $this sh:target ?target . ?target ?p2 ?o2 }
}""" .

med:Component_sousClasseDe a sh:ConstraintComponent;
  sh:parameter _:d85f7e570c704b5b9b53672428339dae826;
  sh:labelTemplate "The value must be a subClassOf {$sousClasseDe}";
  sh:nodeValidator med:Component_sousClasseDe-nodeValidator;
  sh:propertyValidator med:Component_sousClasseDe-propertyValidator .

_:d85f7e570c704b5b9b53672428339dae826 sh:path med:sousClasseDe;
  sh:name "sous-classe de"@fr, "subClass of"@en;
  sh:description "The class of which the value is expected to be a subClassOf"@en .

med:Component_sousClasseDe-nodeValidator a sh:SPARQLSelectValidator;
  sh:message "Value is not an rdfs:subClassOf {$sousClasseDe}";
  sh:select """PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?this WHERE {
 FILTER NOT EXISTS { 
 ?this rdfs:subClassOf+ $sousClasseDe .
 }
}""" .

med:Component_sousClasseDe-propertyValidator a sh:SPARQLSelectValidator;
  sh:message "Value is not an rdfs:subClassOf {$sousClasseDe}";
  sh:select """PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?this ?value WHERE {
 ?this ?PATH ?value .
 FILTER NOT EXISTS { 
 ?value rdfs:subClassOf+ $sousClasseDe .
 }
}""" .

med:Component_closedBySuperClasses a sh:ConstraintComponent;
  sh:parameter _:d85f7e570c704b5b9b53672428339dae827;
  sh:labelTemplate "The property does not belong to a superclass";
  sh:nodeValidator med:Component_closedBySuperClasses-nodeValidator .

_:d85f7e570c704b5b9b53672428339dae827 sh:path med:closedBySuperClasses;
  sh:name "fermé par les super classes"@fr, "closed by super classes"@en .

med:Component_closedBySuperClasses-nodeValidator a sh:SPARQLSelectValidator;
  sh:message "Predicate not allowed {$path} : closed by super classes";
  sh:select """PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX sh: <http://www.w3.org/ns/shacl#>
SELECT $this (?predicate AS ?path) ?value
WHERE {
 FILTER ($closedBySuperClasses) .
 $this ?predicate ?value .
 FILTER (?predicate NOT IN (rdf:type, rdfs:subClassOf, owl:equivalentTo)) .
 FILTER NOT EXISTS {
 $this rdfs:subClassOf* ?class .
 ?class sh:property/sh:path ?predicate .
 }
}""" .

