med:P152 sh:path med:prescriptibleComme;
  sh:name "prescriptible comme";
  sh:description "Référence à une prescription en dénomination commune à laquelle cette présentation peut correspondre. Une présentation peut correspondre à plusieurs prescription en DC. Cette référence n'est pas renseignée pour les spécialités non virtualisables ou les spécialités virtualisables mais faisant exception à la prescription en DC.";
  sh:nodeKind sh:IRI;
  sh:class med:PrescriptionEnDC .

med:P153 sh:path med:quantiteConditionnement;
  sh:name "quantité du conditionnement primaire";
  sh:description "Donne le volume, le poids, le nombre de doses ou la quantité de radioactivité contenue dans la présentation. L'unité est donnée dans un autre attribut.";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:decimal;
  shacl-play:background-color "#EAF1DD" .

med:P154 sh:path med:uniteQuantiteConditionnement;
  sh:name "unité de la quantité du conditionnement primaire";
  sh:description "Donne l'unité de la quantité du conditionnement primaire.";
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype cdt:ucumunit;
  shacl-play:background-color "#EAF1DD" .

med:P155 sh:path med:seComposeDe;
  sh:name "se compose de ou des éléments";
  sh:description "Element de présentation contenu dans cette présentation";
  sh:nodeKind sh:IRI;
  sh:class med:ElementPresentation;
  shacl-play:background-color "#EAF1DD" .

med:P156 sh:path med:concernePar;
  sh:name "concernée par";
  sh:description "Référence à un évènement qui concerne cette présentation (typiquement début ou fin de commercialisation).";
  sh:nodeKind sh:IRI;
  sh:class med:Evenement;
  shacl-play:background-color "#EAF1DD" .

med:P157 sh:path med:libelle;
  sh:name "libellé long historisé";
  sh:description "Référence à un libellé long historisé de cette présentation. Chaque libellé historisé porte une date de début, éventuellement une date de fin, et la valeur du libellé.";
  sh:minCount "1"^^xsd:integer;
  sh:node med:BlankNode_LabelWithDates .

med:P158 sh:path med:libelleCourt;
  sh:name "libellé court historisé";
  sh:description "Référence à un libellé court historisé de cette présentation. Chaque libellé historisé porte une date de début, éventuellement une date de fin, et la valeur du libellé.";
  sh:minCount "1"^^xsd:integer;
  sh:node med:BlankNode_LabelWithDates .

med:P159 sh:path med:dosagePresentation;
  sh:name "dosage présentation";
  sh:description "Dosage de présentation possible pour cette présentation. Une même présentation peut posséder plusieurs dosage présentation possible pour la même substance de référence.";
  sh:nodeKind sh:IRI;
  sh:class med:DosagePresentation .

med:P160 sh:path med:dosageConcentration;
  sh:name "dosage concentration";
  sh:description "Dosage en concentration possible pour cette présentation. Une même présentation ne peut posséder qu'un seul dosage concentration pour la même substance de référence";
  sh:nodeKind sh:IRI;
  sh:class med:DosageConcentration .

med:P161 sh:path med:voie;
  sh:name "voie d'administration";
  sh:description "La voie d'administration de cette présentation.";
  sh:minCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:Voie .

med:P162 sh:path med:formeManufacturee;
  sh:name "forme manufacturée";
  sh:description "La forme manufacturée de cette présentation. La forme indiquée à ce niveau peut être plus spécifique que celle indiquée au niveau de la spécialité. Par exemple \"solution injectable\" sur la spécialité, et \"Solution injectable en récipient multidose\" sur une présentation.";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:Forme .

med:P164 sh:path med:compose;
  sh:name "compose";
  sh:description "Présentation dont fait partie cet élément Présentation";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:IRI;
  sh:class med:Presentation;
  shacl-play:background-color "#EAF1DD" .

med:P165 sh:path rdfs:subClassOf;
  sh:name "classement";
  sh:description "Un élément présentation porte 2 informations de classement : il est toujours sous-classe de med:ElementPresentation mais également sous-classe de l'élément de spécialité correspondant. Les élément de présentations héritent de toutes les caractéristiques de l'élément de spécialité correspondant.";
  sh:minCount "2"^^xsd:integer;
  sh:maxCount "2"^^xsd:integer;
  sh:nodeKind sh:IRI;
  shacl-play:background-color "#EAF1DD" .

med:P166 sh:path med:identifiantElement;
  sh:name "identifiant de l'élément";
  sh:description "Identifiant (séquentiel) de l'élément dans la présentation";
  sh:minCount "1"^^xsd:integer;
  sh:maxCount "1"^^xsd:integer;
  sh:nodeKind sh:Literal;
  sh:datatype xsd:string;
  shacl-play:background-color "#EAF1DD" .

