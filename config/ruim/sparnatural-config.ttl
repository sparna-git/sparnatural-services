  a owl:Ontology;
  dct:created "2026-04-27T00:00:00.000Z"^^xsd:dateTime .

shape:Presentation a sh:NodeShape;
  sh:targetClass med:Presentation;
  sh:nodeKind sh:IRI;
  rdfs:label "Présentation"@fr;
  rdfs:comment """Une présentation est identifiée par son code [CIP13](#med:Presentation_med:CIP13). Elle est [liée à la spécialité](#med:Presentation_med:presente) présentée et à l’UCD [contenue dans la présentation](#med:Presentation_med:contientUniteDeDispensation). Conceptuellement, la présentation “[hérite](#med:Presentation_rdfs:subClassOf)” de toutes les caractéristiques de la spécialité dispensée (substances, type de conditionnement, forme manufacturée). La présentation peut être [prescriptible](#med:Presentation_med:prescriptibleComme) dans une ou plusieurs définitions de prescriptions en dénomination commune, si la spécialité dispensée est prescriptible en DC. 

Une présentation porte également l’[historique](#med:Presentation_med:libelle) de tous ses noms. 

La [forme manufacturée](#med:Presentation_med:formeManufacturee) ainsi que les [voies d’administration possibles](#med:Presentation_med:voie) sont indiquées sur les présentations. La forme peut être plus spécifique que la forme indiquée au niveau de la spécialité, par exemple _\"solution\"_ sur la spécialité, et _\"solution en ampoule\"_ ou _\"solution en flacon\"_ sur des présentations."""@fr;
  sh:agentInstruction "Représente une spécialité pharmaceutique dans un certain packaging. Une présentation est identifiée par son code CIP13. Elle est liée à la spécialité présentée et à l’UCD contenue dans la présentation. Conceptuellement, la présentation \\\"hérite\\\" de toutes les caractéristiques de la spécialité dispensée (substances, type de conditionnement, forme manufacturée). Le nombre d’UCD (comme le nombre de comprimés dans la boite), le conditionnement et les éventuels dispositifs d’administration sont indiqués sur la Présentation. Les dates de commercialisation doivent être récupérées sur les Evenements de type \\\"début de commercialisation\\\" ou \\\"arrêt de commercialisation\\\" liés à la présentation. NAVIGATION VOIE : il n'existe PAS de propriété voie directe sur Presentation. Pour filtrer une Présentation par voie d’administration, naviguer obligatoirement via Presentation_presente -> SpecialitePharmaceutique -> SpecialitePharmaceutique_voie."@fr;
  sh:order 13;
  volipi:iconName "fa-thin fa-box";
  sh:property shape:Presentation_label, shape:Presentation_altLabel, shape:Presentation_CIP13,
    shape:Presentation_CIP7, shape:Presentation_nombreUniteDeDispensation, shape:Presentation_typeDispositif,
    shape:Presentation_presente, shape:Presentation_contientUniteDeDispensation, shape:Presentation_concernePar,
    shape:Presentation_quantiteConditionnement, shape:Presentation_uniteQuantiteConditionnement .

shape:UniteCommuneDeDispensation a sh:NodeShape;
  sh:targetClass med:UniteCommuneDeDispensation;
  sh:nodeKind sh:IRI;
  rdfs:label "Unité de Dispensation"@fr;
  rdfs:comment "Une Unité Commune de dispensation est identifiée par son code [UCD13](#med:UniteCommuneDeDispensation_med:codeUCD13). Elle est liée d’une part [à sa spécialité pharmaceutique](#med:UniteCommuneDeDispensation_med:uniteDeDispensationDe) (une et une seule) et d’autre part [aux présentations](#med:UniteCommuneDeDispensation_med:presenteDans) dans lesquelles elle se retrouve (une UCD peut se retrouver dans plusieurs présentations). L’UCD porte l’[historique](#med:UniteCommuneDeDispensation_med:libelle) de tous ses noms."@fr;
  sh:agentInstruction "Représente un comprimé, un flacon, une ampoule, etc. Une Unité Commune de dispensation est identifiée par son code UCD13. Elle est liée d’une part à sa spécialité pharmaceutique (une et une seule) et d’autre part aux présentations dans lesquelles elle se retrouve (une UCD peut se retrouver dans plusieurs présentations)."@fr;
  sh:order 12;
  volipi:iconName "fa-thin fa-capsules";
  sh:property shape:UniteCommuneDeDispensation_label, shape:UniteCommuneDeDispensation_codeUCD13,
    shape:UniteCommuneDeDispensation_codeUCD7, shape:UniteCommuneDeDispensation_uniteDeDispensationDe,
    shape:UniteCommuneDeDispensation_presenteDans .

shape:SpecialitePharmaceutique a sh:NodeShape;
  sh:targetClass med:SpecialitePharmaceutique;
  sh:nodeKind sh:IRI;
  rdfs:label "Spécialité pharmaceutique"@fr;
  rdfs:comment """Une spécialité pharmaceutique est identifiée par son [code CIS](#med:SpecialitePharmaceutique_med:CIS) (code identifiant de spécialité). Elle porte des informations descriptives, comme son code ATC ou ses dates de validité. La classification ATC d’une Spécialité est indiquée dans 3 attributs : 
 - L'attribut [`classificationATC`](#med:SpecialitePharmaceutique_med:classificationATC) donne une référence à l’entrée actuelle de la classification ATC sur laquelle est classée cette Spécialité; 
 - L’attribut [`codeATC`](#med:SpecialitePharmaceutique_med:codeATC) donne le code de l’entrée ATC actuelle; c’est un complément à la référence à l’entrée de la classification ATC, permettant de voir le code, qui est porteur d’informations; 
 - L’attribut [`libelleATC`](#med:SpecialitePharmaceutique_med:libelleATC) donne le libellé de la classification ATC sur laquelle est classée cette Spécialité, tel que fourni dans les données sources. En fonction des évolutions de la classification ATC, ce libellé peut ne pas être identique au libellé de classification ATC sur laquelle est classée cette Spécialité. 

Chaque spécialité est catégorisée selon 2 axes : son [niveau de virtualisation](#med:SpecialitePharmaceutique_med:niveauDeVirtualisation) (virtualisable, non-virtualisable, virtualisable partiellement en PhPID 1), et sa [prescriptibilité en dénomination commune](#med:SpecialitePharmaceutique_med:prescriptibiliteEnDC) : prescriptible, non-prescriptible et prescriptible avec nom de marque. Le cas échéant la [cause de la non-virtualisation](#med:SpecialitePharmaceutique_med:causeNonVirtualisation) et la [cause de l’exception à la prescription en DC](#med:SpecialitePharmaceutique_med:causeExceptionPrescriptionDC) sont indiquées. 

La [forme manufacturée de la Spécialité](#med:SpecialitePharmaceutique_med:formeManufacturee) est indiquée. Cette forme peut être plus générique que la forme indiquée au niveau de chaque présentation de la spécialité, par exemple \"solution\" sur la spécialité, et \"solution en ampoule\" ou \"solution en flacon\" sur des présentations. A de rares exceptions, une seule forme manufacturée est indiquée. 

La [voie d’administration de la Spécialité](#med:SpecialitePharmaceutique_med:voie) est également indiquée.
Une spécialité est liée aux [UCD](#med:UniteCommuneDeDispensation) qui dispensent cette spécialité et aux [présentations](#med:Presentation) qui contiennent cette spécialité. Elle se [décompose](#med:SpecialitePharmaceutique_med:seComposeDe) également en [Eléments](med:Element) contenus dans la spécialité (par exemple une poudre et un solvant).
Une spécialité porte également l’[historique de tous ses noms](#med:SpecialitePharmaceutique_med:libelle). 
Le [titulaire courant de la spécialité](#med:SpecialitePharmaceutique_med:titulaireCourant) est indiqué. Ce titulaire peut évoluer dans le temps, mais seul le titulaire courant est indiqué. 

D’autres caractéristiques de la spécialité liées à son AMM et à son statut courant sont décrites dans la partie “[Autorisations](#med:Autorisation)”. Se reporter également à la section sur les dosages pour la description qualitative et quantitative de la spécialité."""@fr;
  sh:agentInstruction "Une spécialité pharmaceutique représente un médicament autorisé, indépendamment de son packaging. C'est la classe principale. Elle est identifiée par son code CIS (code identifiant de spécialité). Elle porte des informations descriptives, comme son code ATC ou ses dates de validité. La classification ATC d’une Spécialité est indiquée dans l'attribut `classificationATC` qui donne une référence à l’entrée actuelle de la classification ATC sur laquelle est classée cette Spécialité. Chaque spécialité est catégorisée selon sa prescriptibilité en dénomination commune : prescriptible, non-prescriptible et prescriptible avec nom de marque. Le cas échéant la cause de l’exception à la prescription en DC est indiquée. La forme manufacturée de la Spécialité est indiquée. Cette forme peut être plus générique que la forme indiquée au niveau de chaque présentation de la spécialité, par exemple \\\"solution\\\" sur la spécialité, et \\\"solution en ampoule\\\" ou \\\"solution en flacon\\\" sur des présentations. A de rares exceptions, une seule forme manufacturée est indiquée. La voie d’administration de la Spécialité est également indiquée. Une spécialité est liée aux UCD qui dispensent cette spécialité et aux présentations qui contiennent cette spécialité. Elle se décompose également en Eléments contenus dans la spécialité (par exemple une poudre et un solvant). Le titulaire courant de la spécialité est indiqué. Ce titulaire peut évoluer dans le temps, mais seul le titulaire courant est indiqué. D’autres caractéristiques de la spécialité liées à son AMM et à son statut courant sont décrites dans la partie “Autorisations”."@fr;
  sh:order 11;
  volipi:iconName "fa-thin fa-mortar-pestle";
  sh:property shape:SpecialitePharmaceutique_label, shape:SpecialitePharmaceutique_CIS,
    shape:SpecialitePharmaceutique_dateDebut, shape:SpecialitePharmaceutique_dateFin,
    shape:SpecialitePharmaceutique_classificationATC, shape:SpecialitePharmaceutique_classificationATCdirect,
    shape:SpecialitePharmaceutique_concernePar, shape:SpecialitePharmaceutique_typeProcedureCourante,
    shape:SpecialitePharmaceutique_statutCourant, shape:SpecialitePharmaceutique_prescriptibiliteEnDC,
    shape:SpecialitePharmaceutique_justificationPrescriptibiliteEnDC, shape:SpecialitePharmaceutique_SAouFT,
    shape:SpecialitePharmaceutique_substanceActive, shape:SpecialitePharmaceutique_fractionTherapeutique,
    shape:SpecialitePharmaceutique_substancePortantLeDosage, shape:SpecialitePharmaceutique_aPourUniteDeDispensation,
    shape:SpecialitePharmaceutique_aPourPresentation, shape:SpecialitePharmaceutique_titulaireCourant,
    shape:SpecialitePharmaceutique_estSpecialiteDeReferenceDans, shape:SpecialitePharmaceutique_estSpecialiteGeneriqueDans,
    shape:SpecialitePharmaceutique_estSpecialiteSubstituableDans, shape:SpecialitePharmaceutique_voie .

shape:ATC a sh:NodeShape;
  sh:nodeKind sh:IRI;
  rdfs:label "Classification ATC"@fr;
  sh:order 16;
  volipi:iconName "fa-thin fa-folder-tree";
  sh:deactivated true;
  sh:property shape:ATC_labelATC, shape:ATC_codeATC .

shape:Evenement a sh:NodeShape;
  sh:targetClass med:Evenement;
  sh:target shape:Evenement-target;
  sh:nodeKind sh:IRI;
  rdfs:label "Événement"@fr;
  rdfs:comment "Un événement réglementaire [concerne](#med:Evenement_med:concerne) une [Spécialité](#med:Specialite) ou une [Présentation](#med:Presentation) et est caractérisé par son [type d'événement](#med:Evenement_med:typeEvenement) et sa [date d'effet](#med:Evenement_med:dateEffet)."@fr;
  sh:agentInstruction "Un événement qui concerne soit des Spécialités soit des Présentations. Les événéments qui concernent les Spécialités sont de type Autorisation, Changements de procédure, Suspension, etc. Les événements qui concernent les Présentations sont de type Début de commercialisation ou Arrêt de commercialisation."@fr;
  sh:order 15;
  volipi:iconName "fa-thin fa-calendar";
  sh:property shape:Evenement_concerne, shape:Evenement_typeEvenement, shape:Evenement_dateEffet,
    shape:Evenement_label .

shape:Evenement-target sh:select """SELECT $this
WHERE {
 $this a ?classeEvenement .
 VALUES ?classeEvenement {<http://data.esante.gouv.fr/ansm/medicament/Evenement> <http://data.esante.gouv.fr/ansm/medicament/Autorisation>
}
}""" .

shape:Substance a sh:NodeShape;
  sh:targetClass med:Substance;
  sh:nodeKind sh:IRI;
  rdfs:label "Substance"@fr;
  rdfs:comment "Les substances sont identifiées par un [identifiant interne ANSM](#med:Substance_dct:identifier). Elles peuvent être associées à un [code SMS](#med:Substance_med:codeSMS) quand un équivalent existe. Au moins un [libellé](#med:Substance_rdfs:label) en français est donné à la substance, avec potentiellement plusieurs [synonymes](#med:Substance_skos:altLabel:)."@fr;
  sh:agentInstruction "Une substance dans un médicament, soit une substance de base, soit un sel ou un acide, etc. Les substances sont identifiées par un identifiant interne. Elles peuvent être associées à un code SMS quand un équivalent existe. Au moins un libellé en français est donné à la substance, avec potentiellement plusieurs synonymes. NAVIGATION NOM SPÉCIALITÉ : pour filtrer les substances d'une spécialité par le nom de la spécialité (ex: \"HUMEX RHUME\"), NE PAS utiliser values sur Substance_estSubstanceActiveDans. Naviguer via predicateObjectPairs vers SpecialitePharmaceutique, puis ajouter un predicateObjectPair vers SpecialitePharmaceutique_label (Cat.B, filter:search) avec un searchFilter sur le nom cherché."@fr;
  sh:order 14;
  volipi:iconName "fa-thin fa-atom";
  sh:property shape:Substance_notation, shape:Substance_codeSMS, shape:Substance_label,
    shape:Substance_altLabel, shape:Substance_created, shape:Substance_estFractionTherapeutiqueDans,
    shape:Substance_estSubstanceActiveDans, shape:Substance_exactMatch .

shape:GroupeGenerique a sh:NodeShape;
  sh:targetClass med:GroupeGenerique;
  sh:nodeKind sh:IRI;
  rdfs:label "Groupe générique"@fr;
  rdfs:comment "Les groupes génériques regroupent les spécialités par des liens de différentes natures. Chaque groupe générique indique en général une [spécialité de référence](#med:GroupeGenerique_med:specialiteDeReference) (mais pas toujours, certains groupes n’ont aucune spécialité de référence), et donne les spécialités génériques [équivalentes](#med:GroupeGenerique_med:specialiteGenerique) et les autres spécialités [substituables](#med:GroupeGenerique_med:specialiteSubstituable)."@fr;
  sh:agentInstruction "Un groupe regroupant des spécialités équivalentes. Les groupes génériques regroupent les spécialités par des liens de différentes natures. Chaque groupe générique indique en général une spécialité de référence (mais pas toujours, certains groupes n’ont aucune spécialité de référence), et donne les spécialités génériques équivalentes et les autres spécialités substituables."@fr;
  sh:order 19;
  volipi:iconName "fa-thin fa-sitemap";
  sh:property shape:GroupeGenerique_notation, shape:GroupeGenerique_label, shape:GroupeGenerique_specialiteDeReference,
    shape:GroupeGenerique_specialiteGenerique, shape:GroupeGenerique_specialiteSubstituable .

shape:Organisation a sh:NodeShape;
  sh:targetClass med:Organisation;
  sh:nodeKind sh:IRI;
  rdfs:label "Organisation"@fr;
  rdfs:comment "Une organisation, typiquement un laboratoire pharmaceutique."@fr;
  sh:agentInstruction "Un laboratoire pharmaceutique titulaire d'une autorisation de spécialité."@fr;
  sh:order 20;
  volipi:iconName "fa-thin fa-users";
  sh:deactivated true;
  sh:property shape:Organisation_notation, <https://sparna-git.github.io/referentiel-medicaments/configs/sparnatural-config.ttl#Organisation_label   >,
    shape:Organisation_nomPays .

shape:ElementPresentation a sh:NodeShape;
  sh:targetClass med:ElementPresentation;
  sh:nodeKind sh:IRI;
  rdfs:label "Élément Présentation"@fr;
  rdfs:comment """De la même façon qu'une [Spécialité](#med:SpecialitePharmaceutique) se décompose en [éléments de Spécialité](#med:Element), une [Présentation](#med:Presentation) se décompose en éléments de Présentation. L'élément de Présentation représente les caractéristiques d'un élément de Spécialité donné *dans cette présentation donnée*. Le [type de contenant](#med:ElementPresentation_med:typeContenant) peut par exemple varier d'une présentation à l'autre, pour le même élément de Spécialité (solution buvable, tantôt en flacon, tantôt en ampoule). 

Les éléments de présentation peuvent être classés dans des catégories de produits pharmaceutiques, soit : 
- Sur un [PhPID4](#med:ElementPresentation_med:classementSubstanceDosageForme) si la spécialité dispensée est virtualisable. 
- Sur un [PhPID1](#med:ElementPresentation_med:classementSubstance) si la spécialité est non-virtualisable."""@fr .

shape:TypeEvenement a sh:NodeShape;
  sh:targetClass med:TypeEvenement;
  sh:nodeKind sh:IRI;
  rdfs:label "Type d'événement"@fr;
  rdfs:comment "Liste de toutes les catégories d'[événements](#med:Evenement) que peut décrire le référentiel du médicament, aussi bien sur les spécialités que sur les présentations."@fr;
  sh:agentInstruction "Le type d'un événement, Autorisation, Changements de procédure, Suspension, etc."@fr;
  sh:order 21;
  volipi:iconName "fa-thin fa-list";
  sh:deactivated true;
  sh:property shape:TypeEvenement_label .

shape:TypeProcedure a sh:NodeShape;
  sh:targetClass med:TypeProcedure;
  sh:nodeKind sh:IRI;
  rdfs:label "Type de procédure"@fr;
  rdfs:comment "Liste de toutes les catégories de procédures que peut décrire le référentiel du médicament sur les spécialités pharmaceutiques. Cette liste est utilisée pour code le [type de procédure courante](#med:SpecialitePharmaceutique_med:typeProcedureCourante) d'une spécialité."@fr;
  sh:agentInstruction "Le type d'une procédure d'autorisation de Spécialité, comme \\\"Procédure nationale\\\", \\\"Procédure de reconnaissance mutuelle\\\", \\\"Procédure décentralisée\\\", \\\"Autorisation d'importation parallèle\\\", etc."@fr;
  sh:order 22;
  volipi:iconName "fa-thin fa-list";
  sh:deactivated true;
  sh:property shape:TypeProcedure_label .

shape:StatutSpecialite a sh:NodeShape;
  sh:targetClass med:StatutSpecialite;
  sh:nodeKind sh:IRI;
  rdfs:label "Statut"@fr;
  rdfs:comment "Le statut est l'état de l'autorisation de la spécialité pharmaceutique : actif, archivé, suspendu, retiré... Cette liste est utilisée pour coder le [statut courant d'une spécialité](#med:SpecialitePharmaceutique_med:statutCourant)."@fr;
  sh:agentInstruction "Le statut d'une Spécialité, qui peut être \\\"Actif\\\", \\\"Archivé\\\", \\\"Archivé administratif\\\", \\\"Retiré\\\" ou \\\"Suspension\\\""@fr;
  sh:order 23;
  volipi:iconName "fa-thin fa-list";
  sh:deactivated true;
  sh:property shape:StatutSpecialite_label .

shape:NiveauPrescriptibilite a sh:NodeShape;
  sh:targetClass med:NiveauPrescriptibilite;
  sh:nodeKind sh:IRI;
  rdfs:label "Niveau de prescriptibilité"@fr;
  rdfs:comment "Liste des catégories de spécialités selon la possibilité de les prescrire en dénomination commune : non prescriptible, prescriptible avec nom de marque, prescriptible. Cette liste est utilisée par coder la [prescriptibilité en DC](#med:SpecialitePharmaceutique_med:prescriptibiliteEnDC) des spécialités."@fr;
  sh:agentInstruction "Liste des catégories de spécialités selon la possibilité de les prescrire en dénomination commune : non prescriptible, prescriptible avec nom de marque, prescriptible. Cette liste est utilisée par coder la prescriptibilité en DC des spécialités."@fr;
  sh:order 24;
  volipi:iconName "fa-thin fa-list";
  sh:deactivated true;
  sh:property shape:NiveauPrescriptibilite_label .

shape:JustificationNiveauPrescriptibilite a sh:NodeShape;
  sh:targetClass med:JustificationNiveauPrescriptibilite;
  sh:nodeKind sh:IRI;
  rdfs:label "Justification du niveau de prescriptibilité"@fr;
  rdfs:comment "Liste contrôlée des justifications du niveau de prescriptiilité en dénomination commune (\"plus de trois substances\", \"gaz médicinal\", etc.), utilisée par la propriété de [justification du niveau de prescriptibilité des spécialités](#med:SpecialitePharmaceutique_med:justificationPrescriptibiliteEnDC)"@fr;
  sh:agentInstruction "Liste contrôlée des justifications du niveau de prescriptiilité en dénomination commune (\\\"plus de trois substances\\\", \\\"gaz médicinal\\\", etc.), utilisée par la propriété de justification du niveau de prescriptibilité des spécialités"@fr;
  sh:order 25;
  volipi:iconName "fa-thin fa-list";
  sh:deactivated true;
  sh:property shape:JustificationNiveauPrescriptibilite_label .

shape:Voie a sh:NodeShape;
  sh:targetClass med:Voie;
  sh:nodeKind sh:IRI;
  rdfs:label "Voie"@fr;
  sh:agentInstruction "Une voie d'administration d'une spécialité, comme \\\"orale\\\", \\\"intra-veineuse\\\", \\\"injectable\\\", etc."@fr;
  sh:order 26;
  volipi:iconName "fa-thin fa-list";
  sh:deactivated true;
  sh:property shape:Voie_label .

shape:SubstanceSMS a sh:NodeShape;
  sh:targetClass <http://data.esante.gouv.fr/ema/sms>;
  sh:nodeKind sh:IRI;
  rdfs:label "Substance SMS"@fr;
  sh:agentInstruction "Un identifiant de substance de l'EMA"@fr;
  sh:order 14;
  volipi:iconName "fa-thin fa-atom";
  sh:deactivated true;
  sh:property shape:SubstanceSMS_label .

shape:Text a sh:NodeShape;
  sh:nodeKind sh:Literal;
  rdfs:label "Libellé"@fr;
  sh:agentInstruction "Un texte litéral"@fr;
  sh:order 10;
  volipi:iconName "fa-thin fa-message" .

shape:Date a sh:NodeShape;
  sh:nodeKind sh:Literal;
  rdfs:label "Date"@fr;
  sh:agentInstruction "Une date litérale"@fr;
  sh:order 18;
  volipi:iconName "fa-thin fa-calendar-day" .

shape:Code a sh:NodeShape;
  sh:nodeKind sh:Literal;
  rdfs:label "Code"@fr;
  sh:agentInstruction "Une valeur de code en texte"@fr;
  sh:order 17;
  volipi:iconName "fa-thin fa-barcode" .

shape:CodeUnité a sh:NodeShape .

shape:NombreUnites a sh:NodeShape;
  sh:nodeKind sh:Literal;
  rdfs:label "Nombre d'unités de dispensation"@fr;
  sh:agentInstruction "Un nombre d'unités en numérique"@fr;
  volipi:iconName "fa-thin fa-cubes" .

shape:TypeDispositif a sh:NodeShape;
  sh:nodeKind sh:Literal;
  rdfs:label "Dispositif d'administration"@fr;
  sh:agentInstruction "Un type de dispositif d'administration, comme \\\"avec aiguilles\\\", \\\"avec gobelet doseur\\\", etc. C'est une chaine de caractères libre, pas une liste contrôlée."@fr;
